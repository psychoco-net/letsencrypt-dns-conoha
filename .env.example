# ConoHa Region (v2: tyo1 or tyo2, v3: c3j1)
CNH_REGION=c3j1

# ConoHa API Tenant ID
CNH_TENANT_ID=TenantID

# ConoHa API User name
CNH_USERNAME=UserName(gncu----)

# ConoHa API User Password
CNH_PASSWORD=Password

# --- Log rotation (optional; defaults used if omitted) ---
# Rotate conoha_dns.log when it exceeds this size in bytes (default 1048576 = 1 MiB)
LOG_MAX_BYTES=1048576

# Number of rotated generations to keep (default 3)
LOG_GENERATIONS=3
